# Weekly Finance Brief — env template. Copy to .env.local and fill in.
# Real keys live ONLY in .env.local (gitignored). Never commit secrets.

# --- Data sources ---
FRED_API_KEY=
ALPHAVANTAGE_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
# Dev sandbox sender: onboarding@resend.dev. Production: a verified domain sender.
EMAIL_FROM=onboarding@resend.dev

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Supabase ---
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — SERVER ONLY
SUPABASE_SERVICE_KEY=

# --- Generation providers ---
# Primary: Gemini free tier (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=
# Claude CLI emergency fallback on the owner's subscription: on | off
BRIEF_FALLBACK_CLI=on

# --- Anthropic API (only needed if switching to metered API at commercial scale) ---
ANTHROPIC_API_KEY=

# --- Ops ---
CRON_SECRET=
ADMIN_EMAIL=
APP_BASE_URL=http://localhost:3000
